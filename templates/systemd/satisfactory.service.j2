[Unit]
Description=Satisfactory Dedicated Server.
After=syslog.target network.target nss-lookup.target network-online.target
Wants=network.target

[Service]
Type=simple
RestartSec=60s
{% if satisfactory_flg_update %}
ExecStartPre={{ satisfactory___app._steamcmd }} +app_update {{ satisfactory___release._app_id }} -beta {{ satisfactory__srv._branch }} {{ satisfactory__srv._update_opts }} +quit
{% endif %}
ExecStart={{ satisfactory___app._bin }} {{ satisfactory__srv._launch_opts }}
WorkingDirectory={{ satisfactory___app._root_d }}
Environment="LD_LIBRARY_PATH={{ satisfactory___app._root_d }}/linux64"
KillSignal=SIGINT
Restart=always
User={{ steam__ctx._user }}
Group={{ steam__ctx._group }}

[Install]
WantedBy=multi-user.target